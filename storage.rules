rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function workspaceMember(workspaceId) {
      return signedIn() &&
        firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.uid == request.auth.uid;
    }

    match /workspaces/{workspaceId}/{allPaths=**} {
      allow read: if workspaceMember(workspaceId);
      allow write: if workspaceMember(workspaceId);
    }
  }
}
